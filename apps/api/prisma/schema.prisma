generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ResellerStatus {
  ATIVA
  INATIVA
  EM_PROSPECCAO
}

model Reseller {
  id           Int             @id
  name         String
  street       String
  number       String
  neighborhood String
  city         String
  state        String
  zipCode      String
  status       ResellerStatus
  latitude     Float?
  longitude    Float?
  geocodedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([zipCode])
  @@index([city])
  @@index([status, latitude, longitude])
  @@index([name, street, neighborhood, city])
}
